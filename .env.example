# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:8081

# ── Database (matches docker-compose.yml) ───────────────
DATABASE_URL=postgres://zero:zero_password@localhost:5432/zero_db

# ── Auth ────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=30d
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
# In dev, OTP is printed to logs instead of being sent over SMS
OTP_DEV_MODE=true

# ── MSG91 (OTP SMS) ─────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_SENDER_ID=ZERODL
MSG91_OTP_TEMPLATE_ID=
MSG91_ROUTE=4

# ── PayU (payments) ─────────────────────────────────────
# Use test creds for dev: https://test.payu.in  | live: https://secure.payu.in
PAYU_MODE=test
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=
PAYU_BASE_URL=https://test.payu.in
# Where PayU redirects after payment (mobile deep link or web)
PAYU_SUCCESS_URL=http://localhost:4000/api/v1/payments/payu/callback
PAYU_FAILURE_URL=http://localhost:4000/api/v1/payments/payu/callback
# TEST ONLY: skip the gateway and auto-mark online payments as paid.
# Set to false once PayU keys above are filled in.
PAYMENTS_DEV_BYPASS=true

# ── App defaults ────────────────────────────────────────
DEFAULT_CURRENCY=INR
SUPPORT_PHONE=+919999999999
